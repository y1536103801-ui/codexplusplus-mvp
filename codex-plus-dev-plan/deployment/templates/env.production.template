# Codex++ production environment template.
# Copy to /opt/codex-plus/.env.production on the server.
# Do not commit real values.

ENVIRONMENT=production

# Domains
API_DOMAIN=api.codex.example.com
ADMIN_DOMAIN=admin.codex.example.com
PUBLIC_BASE_URL=https://api.codex.example.com
ADMIN_PUBLIC_URL=https://admin.codex.example.com
CORS_ALLOWED_ORIGINS=https://admin.codex.example.com

# Images
SUB2API_BACKEND_IMAGE=registry.example.com/codex-plus/sub2api-backend:REPLACE_ME
SUB2API_ADMIN_IMAGE=registry.example.com/codex-plus/sub2api-admin:REPLACE_ME

# Internal ports
BACKEND_INTERNAL_PORT=3000
ADMIN_INTERNAL_PORT=80

# Database
POSTGRES_DB=codex_plus
POSTGRES_USER=codex_plus
POSTGRES_PASSWORD=REPLACE_WITH_SERVER_SECRET
DATABASE_URL=postgres://codex_plus:REPLACE_WITH_SERVER_SECRET@postgres:5432/codex_plus?sslmode=disable

# Redis
REDIS_PASSWORD=REPLACE_WITH_SERVER_SECRET
REDIS_URL=redis://:REPLACE_WITH_SERVER_SECRET@redis:6379/0

# Auth/session
JWT_SECRET=REPLACE_WITH_SERVER_SECRET
SESSION_SECRET=REPLACE_WITH_SERVER_SECRET

# Upstream model provider
UPSTREAM_PROVIDER_NAME=REPLACE_ME
UPSTREAM_PROVIDER_BASE_URL=REPLACE_ME
UPSTREAM_PROVIDER_API_KEY=REPLACE_WITH_SERVER_SECRET

# Payment
PAYMENT_ENABLED=false
PAYMENT_PROVIDER=REPLACE_ME
PAYMENT_WEBHOOK_SECRET=REPLACE_WITH_SERVER_SECRET

# Cost and abuse controls
DAILY_COST_CAP_CENTS=REPLACE_ME
USER_DAILY_COST_CAP_CENTS=REPLACE_ME
MAINTENANCE_MODE=false

# Logs and backups
LOG_LEVEL=info
BACKUP_RETENTION_DAYS=7
