{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex+++",
  "version": "0.1.39",
  "identifier": "com.codexppp.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Codex+++",
        "width": 1120,
        "height": 780,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "publisher": "Codex+++",
    "shortDescription": "Codex+++ Windows client",
    "longDescription": "Codex+++ Windows client for logging in, checking token balance, requesting token top-ups, checking local Codex status, installing Codex automatically, and launching Codex."
  }
}
