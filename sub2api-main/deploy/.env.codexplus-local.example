# =============================================================================
# Sub2API Codex++ Local Source Runtime Example
# =============================================================================
# Copy this file to .env.codexplus-local before running docker-compose.dev.yml.
# Do not commit .env.codexplus-local. It contains local secrets.

BIND_HOST=127.0.0.1
SUB2API_DEV_HOST_PORT=8081
SUB2API_DEV_IMAGE=sub2api-codexplus-local:dev
SUB2API_DEV_APP_CONTAINER=sub2api-codexplus-local
SUB2API_DEV_POSTGRES_CONTAINER=sub2api-codexplus-postgres
SUB2API_DEV_REDIS_CONTAINER=sub2api-codexplus-redis
SUB2API_DEV_DATA_ROOT=./.codexplus-local

# Use pipe separators so Go can fall back after transient proxy errors.
GOPROXY=https://goproxy.cn|https://proxy.golang.org|direct
GOSUMDB=sum.golang.google.cn

POSTGRES_USER=sub2api
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=sub2api
REDIS_PASSWORD=
REDIS_DB=0

ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=change_this_admin_password
# Local-only example values. Replace both before any shared or production-like use.
# Generate new values with: [Convert]::ToHexString([Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).ToLowerInvariant()
JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
TOTP_ENCRYPTION_KEY=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789

TZ=Asia/Shanghai
RUN_MODE=standard
